{
  "name": "comecix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm:server\" \"vite\"",
    "build": "vite build && node scripts/copy-404.js",
    "preview": "vite preview",
    "server": "concurrently \"json-server --watch db.json --port 3000\" \"json-server --watch users.json --port 3001\" \"json-server --watch orders.json --port 3002\"",
    "server:products": "json-server --watch db.json --port 3000",
    "server:users": "json-server --watch users.json --port 3001",
    "server:orders": "json-server --watch orders.json --port 3002",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "gh-pages": "^6.2.0",
    "json-server": "^1.0.0-beta.3",
    "vite": "^6.0.5"
  }
}
