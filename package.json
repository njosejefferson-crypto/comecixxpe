{
  "name": "ecommerce-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "concurrently \"json-server --watch db.json --port 3000\" \"json-server --watch users.json --port 3001\" \"json-server --watch orders.json --port 3002\"",
    "server:products": "json-server --watch db.json --port 3000",
    "server:users": "json-server --watch users.json --port 3001",
    "server:orders": "json-server --watch orders.json --port 3002"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.1.0",
    "jsdom": "^28.0.0",
    "json-server": "^1.0.0-beta.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
